WEB_ADMIN_PASSWORD=change-me-now
JWT_SECRET=replace-with-a-long-random-string
DASHBOARD_HOST_PORT=3000
DASHBOARD_CONTAINER_PORT=80

SATISFACTORY_CONTAINER_NAME=satisfactory-server
SATISFACTORY_IMAGE=wolveix/satisfactory-server:latest
SATISFACTORY_API_URL=https://satisfactory-server:7777/api/v1

# Optional, but needed for admin functions such as saves/uploads.
# Prefer an application token generated with server.GenerateAPIToken.
SATISFACTORY_API_TOKEN=
SATISFACTORY_ADMIN_PASSWORD=

# Optional live player locations via Ficsit Remote Monitoring.
# Example when exposed in the same compose network: http://satisfactory-server:8080
FRM_BASE_URL=

MAXPLAYERS=4
PUID=1000
PGID=1000
STEAMBETA=false
SKIPUPDATE=false
