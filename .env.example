WEB_ADMIN_PASSWORD=change-me-now
JWT_SECRET=replace-with-a-long-random-string
DASHBOARD_CONTAINER_PORT=80
DASHBOARD_DEV_API_PORT=8080
DASHBOARD_MEMORY_LIMIT=768m

SATISFACTORY_CONTAINER_NAME=satisfactory-server
SATISFACTORY_SERVICE_NAME=satisfactory-server
SATISFACTORY_IMAGE=wolveix/satisfactory-server:latest
SATISFACTORY_HOST_IP=0.0.0.0
SATISFACTORY_GAME_TCP_HOST_PORT=7777
SATISFACTORY_GAME_UDP_HOST_PORT=7777
SATISFACTORY_MESSAGING_HOST_PORT=8888
SERVERGAMEPORT=7777
SERVERMESSAGINGPORT=8888

SATISFACTORY_API_PROTOCOL=https
SATISFACTORY_API_HOST=satisfactory-server
SATISFACTORY_API_PORT=7777
SATISFACTORY_API_URL=

# Optional, but needed for admin functions such as saves/uploads.
# Prefer an application token generated with server.GenerateAPIToken.
SATISFACTORY_API_TOKEN=
SATISFACTORY_ADMIN_PASSWORD=

# Optional live player locations via Ficsit Remote Monitoring.
# Example when exposed in the same compose network: http://satisfactory-server:8080
FRM_BASE_URL=
ENABLE_SAVE_MAP_PARSING=false
MAX_SAVE_PARSE_BYTES=104857600

MAXPLAYERS=4
PUID=1000
PGID=1000
STEAMBETA=false
SKIPUPDATE=false
